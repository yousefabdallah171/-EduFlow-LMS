generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  STUDENT
}

enum Locale {
  en
  ar
}

enum Theme {
  light
  dark
}

enum OAuthProvider {
  email
  google
}

enum EnrollmentStatus {
  ACTIVE
  REVOKED
  EXPIRED
}

enum EnrollmentType {
  PAID
  ADMIN_ENROLLED
}

enum PaymentStatus {
  INITIATED
  AWAITING_PAYMENT
  WEBHOOK_PENDING
  COMPLETED
  FAILED
  CANCELLED
  ENROLLMENT_FAILED
  EMAIL_FAILED
  REFUND_REQUESTED
  REFUNDED
  REFUND_FAILED
  DISPUTED
  MANUAL_OVERRIDE
}

enum PaymentEventType {
  INITIATED
  PAYMENT_KEY_GENERATED
  PAYMOB_API_ERROR
  WEBHOOK_RECEIVED
  WEBHOOK_VERIFIED
  WEBHOOK_DUPLICATE
  STATUS_CHANGED
  ENROLLMENT_TRIGGERED
  ENROLLMENT_SUCCEEDED
  ENROLLMENT_FAILED
  EMAIL_QUEUED
  EMAIL_SENT
  EMAIL_FAILED
  COUPON_INCREMENTED
  REFUND_INITIATED
  REFUND_API_CALL
  REFUND_SUCCEEDED
  REFUND_FAILED
  DISPUTE_RECEIVED
  MANUAL_OVERRIDE_APPLIED
  PAYMENT_POLLED
}

enum PaymentMethod {
  CARD
  MOBILE_WALLET
  BANK_TRANSFER
}

enum RefundStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum CouponDiscountType {
  PERCENTAGE
  FIXED
}

enum VideoStatus {
  NONE
  PROCESSING
  READY
  ERROR
}

enum UploadStatus {
  UPLOADING
  COMPLETE
  PROCESSING
  READY
  CANCELLED
  ERROR
}

model User {
  id                   String           @id @default(uuid())
  email                String           @unique
  passwordHash         String?
  fullName             String
  avatarUrl            String?
  role                 Role             @default(STUDENT)
  locale               Locale           @default(en)
  theme                Theme            @default(light)
  oauthProvider        OAuthProvider    @default(email)
  oauthId              String?          @unique
  emailVerified        Boolean          @default(false)
  emailVerifyToken     String?
  emailVerifyExpires   DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  refreshTokens        RefreshToken[]
  enrollments          Enrollment[]     @relation("StudentEnrollment")
  payments             Payment[]
  lessonProgress       LessonProgress[]
  videoTokens          VideoToken[]
  videoUploads         VideoUpload[]    @relation("UploadUser")
  revokedEnrollments   Enrollment[]     @relation("RevokedBy")
  updatedCourse        CourseSettings[] @relation("CourseUpdatedBy")
  notes                Note[]
  auditLogs            AuditLog[]       @relation("AdminAuditLogs")
  videoSecurityEvents  VideoSecurityEvent[]
  tickets              SupportTicket[]  @relation("TicketUser")
  ticketMessages       TicketMessage[]  @relation("MessageSender")
  adminAuditLogs       AdminAuditLog[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  familyId  String
  sessionId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, sessionId])
  @@index([userId, revokedAt])
  @@index([familyId])
  @@index([expiresAt])
}

model Enrollment {
  id             String           @id @default(uuid())
  userId         String           @unique
  user           User             @relation("StudentEnrollment", fields: [userId], references: [id], onDelete: Cascade)
  status         EnrollmentStatus @default(ACTIVE)
  enrollmentType EnrollmentType
  paymentId      String?          @unique
  payment        Payment?         @relation(fields: [paymentId], references: [id])
  enrolledAt     DateTime         @default(now())
  revokedAt      DateTime?
  revokedById    String?
  revokedBy      User?            @relation("RevokedBy", fields: [revokedById], references: [id])

  @@index([status])
  @@index([enrolledAt])
  @@index([revokedAt])
}

model Payment {
  id                      String         @id @default(uuid())
  userId                  String
  user                    User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  packageId               String?
  package                 CoursePackage? @relation(fields: [packageId], references: [id])
  amountPiasters          Int
  currency                String         @default("EGP")
  couponId                String?
  coupon                  Coupon?        @relation(fields: [couponId], references: [id])
  discountPiasters        Int            @default(0)

  status                  PaymentStatus  @default(INITIATED)
  paymentMethod           PaymentMethod?

  paymobOrderId           String?        @unique
  paymobTransactionId     String?        @unique
  paymobIdempotencyKey    String?        @unique

  webhookReceivedAt       DateTime?
  webhookHmac             String?
  webhookPayload          Json?
  webhookRetryCount       Int            @default(0)
  webhookLastRetryAt      DateTime?
  webhookNextRetryAt      DateTime?

  enrollmentRetryCount    Int            @default(0)
  enrollmentLastRetryAt   DateTime?
  enrollmentNextRetryAt   DateTime?

  recoveryAttempts        Json?

  errorCode               String?
  errorMessage            String?
  errorDetails            Json?

  refundInitiatedAt       DateTime?
  refundInitiatedBy       String?
  refundAmount            Int?
  refundStatus            RefundStatus?
  refundRetryCount        Int            @default(0)
  refundLastRetryAt       DateTime?
  refundNextRetryAt       DateTime?
  paymobRefundId          String?        @unique
  refundCompletedAt       DateTime?

  disputedAt              DateTime?
  disputeReason           String?
  resolvedAt              DateTime?
  resolvedBy              String?

  ipAddress               String?
  userAgent               String?

  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  enrollment              Enrollment?
  events                  PaymentEvent[]
  reconciliations         PaymentReconciliation[]
  failedPaymentQueue      FailedPaymentQueue? @relation("FailedPaymentQueue")
  emailQueue              EmailQueue[] @relation("EmailQueue")
  webhookRetryQueue       WebhookRetryQueue? @relation("WebhookRetryQueue")
  refundQueue             RefundQueue?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([paymobOrderId])
  @@index([paymobTransactionId])
  @@index([paymobIdempotencyKey])
  @@index([refundStatus])
  @@index([paymobRefundId])
}

model RefundQueue {
  id                  String            @id @default(uuid())
  paymentId           String            @unique
  payment             Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  refundType          String            // "FULL" or "PARTIAL"
  refundAmount        Int
  reason              String?

  retryCount          Int               @default(0)
  maxRetries          Int               @default(3)

  firstAttempt        DateTime          @default(now())
  lastAttempt         DateTime?
  nextRetry           DateTime?

  resolvedAt          DateTime?
  resolution          String?           // "COMPLETED", "FAILED", "CANCELLED"

  errorDetails        Json?

  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([paymentId])
  @@index([nextRetry])
  @@index([resolution])
}

model PaymentEvent {
  id              String            @id @default(uuid())
  paymentId       String
  payment         Payment           @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  eventType       PaymentEventType
  status          PaymentStatus?
  previousStatus  PaymentStatus?

  errorCode       String?
  errorMessage    String?

  metadata        Json?

  createdAt       DateTime          @default(now())

  @@index([paymentId])
  @@index([paymentId, createdAt])
  @@index([eventType])
  @@index([eventType, createdAt])
  @@index([createdAt])
}

model PaymentReconciliation {
  id              String    @id @default(uuid())
  paymentId       String
  payment         Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  paymobStatus    String?
  localStatus     String

  paymobAmount    Int?
  localAmount     Int
  amountMismatch  Boolean   @default(false)

  isReconciled    Boolean   @default(false)
  reconciliedAt   DateTime?
  reconciliedBy   String?
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([paymentId])
  @@index([isReconciled])
}

model FailedPaymentQueue {
  id            String    @id @default(uuid())
  paymentId     String    @unique
  payment       Payment   @relation("FailedPaymentQueue", fields: [paymentId], references: [id], onDelete: Cascade)

  failureType   String    // TRANSIENT, USER_ERROR, SYSTEM_ERROR
  failureCode   String    // PAYMOB_TIMEOUT, INVALID_COUPON, etc.
  failureReason String

  retryCount    Int       @default(0)
  maxRetries    Int       @default(3)

  firstAttempt  DateTime  @default(now())
  lastAttempt   DateTime  @updatedAt
  nextRetry     DateTime?

  resolvedAt    DateTime?
  resolvedBy    String?   // Admin user ID
  resolution    String?   // MANUAL_OVERRIDE, AUTO_RETRY, REFUND

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([resolvedAt])
  @@index([nextRetry])
  @@index([failureType])
}

model EmailQueue {
  id          String    @id @default(uuid())
  paymentId   String?
  payment     Payment?  @relation("EmailQueue", fields: [paymentId], references: [id], onDelete: SetNull)

  recipient   String
  emailType   String    // PAYMENT_RECEIPT, ENROLLMENT_ACTIVATED, REFUND_NOTICE
  subject     String
  template    String
  context     Json

  retryCount  Int       @default(0)
  maxRetries  Int       @default(5)

  status      String    // PENDING, SENT, FAILED_PERMANENT, BOUNCED, DLQ
  lastError   String?
  errorCode   String?   // SMTP error code if applicable

  firstAttempt DateTime  @default(now())
  lastAttempt  DateTime  @updatedAt
  nextRetry    DateTime?

  sentAt      DateTime?
  movedToDlqAt DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([nextRetry])
  @@index([paymentId])
  @@index([status, createdAt])
}

model WebhookRetryQueue {
  id          String    @id @default(uuid())
  paymentId   String    @unique
  payment     Payment   @relation("WebhookRetryQueue", fields: [paymentId], references: [id], onDelete: Cascade)

  payload     Json
  errorDetails Json?

  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)

  firstAttempt DateTime  @default(now())
  lastAttempt  DateTime  @updatedAt
  nextRetry    DateTime?

  resolvedAt  DateTime?
  resolution  String?   // SUCCESS, FAILED, LATE_WEBHOOK

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([nextRetry])
  @@index([resolvedAt])
}

model AdminAuditLog {
  id          String    @id @default(uuid())
  adminId     String
  admin       User      @relation(fields: [adminId], references: [id], onDelete: Restrict)

  action      String    // OVERRIDE_PAYMENT, CANCEL_PAYMENT, RETRY_PAYMENT, MARK_PAID
  paymentId   String?
  targetId    String?   // ID of affected resource

  reason      String
  metadata    Json?

  createdAt   DateTime  @default(now())

  @@index([adminId])
  @@index([paymentId])
  @@index([createdAt])
  @@index([action, createdAt])
}

model CoursePackage {
  id            String    @id
  titleEn       String
  titleAr       String
  descriptionEn String?
  descriptionAr String?
  pricePiasters Int
  currency      String    @default("EGP")
  isActive      Boolean   @default(true)
  sortOrder     Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  payments      Payment[]

  @@index([isActive, sortOrder])
}

model Coupon {
  id            String             @id @default(uuid())
  code          String             @unique
  discountType  CouponDiscountType
  discountValue Decimal            @db.Decimal(10, 2)
  maxUses       Int?
  usesCount     Int                @default(0)
  expiryDate    DateTime?
  createdAt     DateTime           @default(now())
  deletedAt     DateTime?
  payments      Payment[]
}

model Section {
  id            String   @id @default(uuid())
  titleEn       String
  titleAr       String
  descriptionEn String?
  descriptionAr String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lessons       Lesson[]

  @@index([sortOrder])
}

model Lesson {
  id              String           @id @default(uuid())
  titleEn         String
  titleAr         String
  descriptionEn   String?
  descriptionAr   String?
  videoHlsPath    String?
  videoStatus     VideoStatus      @default(NONE)
  durationSeconds Int?
  sortOrder       Int              @default(0)
  isPublished     Boolean          @default(false)
  isPreview       Boolean          @default(false)
  dripDays        Int?
  sectionId       String?
  section         Section?         @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  progress        LessonProgress[]
  videoTokens     VideoToken[]
  uploads         VideoUpload[]
  notes           Note[]
  resources       LessonResource[]
  videoSecurityEvents VideoSecurityEvent[]

  @@index([isPublished, sortOrder])
  @@index([sectionId, isPublished, sortOrder])
  @@index([isPreview, isPublished])
}

model LessonProgress {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId            String
  lesson              Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completedAt         DateTime?
  watchTimeSeconds    Int       @default(0)
  lastPositionSeconds Int       @default(0)
  updatedAt           DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([lessonId])
}

model VideoToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  sessionId String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([sessionId])
  @@index([userId, sessionId])
  @@index([lessonId, expiresAt])
  @@index([expiresAt])
}

model VideoUpload {
  id           String       @id @default(uuid())
  lessonId     String?
  lesson       Lesson?      @relation(fields: [lessonId], references: [id])
  uploadedById String
  uploadedBy   User         @relation("UploadUser", fields: [uploadedById], references: [id])
  filename     String
  sizeBytes    BigInt
  offsetBytes  BigInt       @default(0)
  status       UploadStatus @default(UPLOADING)
  storagePath  String?
  errorMessage String?
  createdAt    DateTime     @default(now())
  completedAt  DateTime?
}

model CourseSettings {
  id               Int      @id @default(1)
  titleEn          String
  titleAr          String
  descriptionEn    String?
  descriptionAr    String?
  pricePiasters    Int
  currency         String   @default("EGP")
  isEnrollmentOpen Boolean  @default(true)
  updatedAt        DateTime @updatedAt
  updatedById      String?
  updatedBy        User?    @relation("CourseUpdatedBy", fields: [updatedById], references: [id])
}

model Note {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId         String
  lesson           Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content          String
  positionSeconds  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, lessonId])
}

model LessonResource {
  id            String   @id @default(uuid())
  lessonId      String
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title         String
  fileUrl       String
  fileSizeBytes BigInt   @default(0)
  createdAt     DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  admin      User     @relation("AdminAuditLogs", fields: [adminId], references: [id])
  action     String
  targetType String   @default("")
  targetId   String   @default("")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
}

model VideoSecurityEvent {
  id               String   @id @default(uuid())
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId        String?
  lessonId         String?
  lesson           Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  previewSessionId String?
  eventType        String
  severity         String   @default("INFO")
  ip               String?
  userAgent        String?
  fingerprint      String?
  metadata         Json     @default("{}")
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([eventType])
  @@index([userId])
  @@index([sessionId])
  @@index([lessonId])
  @@index([previewSessionId])
}

enum TicketStatus {
  OPEN
  RESOLVED
}

model SupportTicket {
  id        String          @id @default(uuid())
  userId    String
  user      User            @relation("TicketUser", fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  status    TicketStatus    @default(OPEN)
  createdAt DateTime        @default(now())
  messages  TicketMessage[]
}

model TicketMessage {
  id        String        @id @default(uuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User          @relation("MessageSender", fields: [senderId], references: [id])
  body      String
  createdAt DateTime      @default(now())
}

model NotificationTemplate {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  subject   String
  bodyHtml  String
  updatedAt DateTime @updatedAt
}
